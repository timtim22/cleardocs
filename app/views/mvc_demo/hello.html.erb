<div style="max-width: 800px; margin: 0 auto; padding: 20px; font-family: Arial, sans-serif;">
  <h1>👋 Hello Demo</h1>

  <div style="background-color: #d4edda; padding: 20px; border-radius: 8px; border: 1px solid #c3e6cb;">
    <h2><%= @greeting %></h2>
  </div>

  <div style="background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin: 20px 0;">
    <h3>🔍 MVC Flow for this page:</h3>
    <ol>
      <li><strong>Route:</strong> <code>get "hello" => "mvc_demo#hello"</code></li>
      <li><strong>Controller:</strong> <code>MvcDemoController#hello</code> action set @name and @greeting</li>
      <li><strong>View:</strong> This ERB template displays the @greeting variable</li>
    </ol>
  </div>

  <div style="margin: 20px 0;">
    <h3>Try with different names:</h3>
    <%= link_to "Hello Alice", hello_path(name: "Alice"),
        style: "background-color: #007bff; color: white; padding: 8px 15px; text-decoration: none; border-radius: 3px; margin: 5px;" %>
    <%= link_to "Hello Bob", hello_path(name: "Bob"),
        style: "background-color: #007bff; color: white; padding: 8px 15px; text-decoration: none; border-radius: 3px; margin: 5px;" %>
    <%= link_to "Hello Charlie", hello_path(name: "Charlie"),
        style: "background-color: #007bff; color: white; padding: 8px 15px; text-decoration: none; border-radius: 3px; margin: 5px;" %>
  </div>

  <p style="background-color: #fff3cd; padding: 10px; border-radius: 5px; border: 1px solid #ffeaa7;">
    <strong>💡 Notice:</strong> The URL parameter <code>?name=<%= params[:name] || "World" %></code>
    gets passed to the controller via <code>params[:name]</code>
  </p>

  <%= link_to "← Back to Demo Home", root_path,
      style: "background-color: #6c757d; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px;" %>
</div>